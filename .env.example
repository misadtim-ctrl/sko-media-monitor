# Google Apps Script bridge. No paid API keys are used.
APPS_SCRIPT_WEBHOOK_URL=
MONITOR_WEBHOOK_SECRET=

# The bot token stays in Apps Script. These are optional for direct Python delivery.
TELEGRAM_BOT_TOKEN=
TELEGRAM_MAIN_CHAT_ID=
TELEGRAM_NEGATIVE_CHAT_ID=

# Existing Instagram account, used only to load a reusable session.
INSTAGRAM_USERNAME=
INSTAGRAM_SESSION_FILE=data/instagram-session

# Optional official free Meta path for Business/Creator profiles.
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_GRAPH_VERSION=v22.0

ENABLE_SEMANTIC=false
ENABLE_MEDIA_ANALYSIS=false
ENABLE_VIDEO_ANALYSIS=false
CONCURRENCY=8
REQUEST_TIMEOUT=25
